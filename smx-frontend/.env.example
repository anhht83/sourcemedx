NODE_ENV=local

NEXT_PUBLIC_EXTERNAL_API_URL=http://localhost:3001/api
NEXT_PUBLIC_EXTERNAL_DOWNLOAD_URL=http://localhost:3001
NEXT_PUBLIC_INTERNAL_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3001

# Stripe publishable key (pk_test_... / pk_live_...)
NEXT_PUBLIC_STRIPE_PUBKEY=your_stripe_publishable_key

NEXT_PUBLIC_HOME_PATH=/dashboard
NEXT_PUBLIC_LOGIN_PATH=/auth/login
SECRET_API_KEY=your-secret-api-key

# Must match JWT_SECRET in smx-api (e.g. .env.development)
NEXT_PUBLIC_JWT_SECRET=your-jwt-secret

NEXT_PUBLIC_PRICE_PER_KEY=10
NEXT_PUBLIC_DISCOUNT_5=0.05
NEXT_PUBLIC_DISCOUNT_10=0.1
