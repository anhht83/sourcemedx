{
  "name": "smx-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development nodemon",
    "staging": "NODE_ENV=staging node dist/index.js",
    "build": "NODE_ENV=production tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "start:large-files": "NODE_ENV=production node --max-old-space-size=8192 dist/index.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:create": "npm run typeorm -- migration:create",
    "migration:generate": "npm run typeorm -- migration:generate -d src/configs/database.ts",
    "migration:run": "npm run typeorm -- migration:run -d src/configs/database.ts",
    "migration:revert": "npm run typeorm -- migration:revert -d src/configs/database.ts",
    "migration:show": "npm run typeorm -- migration:show -d src/configs/database.ts"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@langchain/core": "^0.3.40",
    "@langchain/openai": "^0.4.4",
    "@nestjs/swagger": "^11.0.6",
    "@sendgrid/mail": "^8.1.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "http": "^0.0.1-security",
    "http-status-codes": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.19",
    "mailersend": "^2.3.0",
    "morgan": "^1.10.0",
    "openai": "^4.85.4",
    "p-limit": "^6.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.13.1",
    "pgvector": "^0.2.0",
    "promise-limit": "^2.7.0",
    "puppeteer": "^24.8.2",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "sax": "^1.4.1",
    "socket.io": "^4.8.1",
    "stream-json": "^1.9.1",
    "stripe": "^18.2.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.20",
    "typeorm-typedi-extensions": "^0.4.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/sax": "^1.2.7",
    "@types/socket.io": "^3.0.1",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.5",
    "eslint-plugin-react": "^7.37.4",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.5.3",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0"
  }
}
