# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=smx
DB_SCHEMA=public
DB_SYNCHRONIZE=true # Set to false in production
DB_SSL=false

# JWT Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=15m # 15 minutes for access token
REFRESH_TOKEN_EXPIRATION=7d # 7 days for refresh token
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production

# Search Key Configuration
SEARCH_KEY_EXPIRATION_DAYS=30
SEARCH_KEY_BASE_PRICE=10.00
SEARCH_KEY_SMALL_BUNDLE=5
SEARCH_KEY_SMALL_DISCOUNT=5
SEARCH_KEY_LARGE_BUNDLE=20
SEARCH_KEY_LARGE_DISCOUNT=10

# Stripe Configuration
STRIPE_SECRET_KEY=your_stripe_secret_key

# Rate Limiting
THROTTLE_TTL=60 # Time-to-live in seconds
THROTTLE_LIMIT=100 # Number of requests per TTL

# Logging
LOG_LEVEL=debug # debug, info, warn, error
LOG_FORMAT=combined # dev, combined, tiny, short

# CORS
CORS_ENABLED=true
CORS_ORIGINS=http://localhost:3001
# CORS_ORIGINS=http://localhost:3001,http://localhost:3000
# CORS_ORIGINS=* (allowing all clients to access)

# Security
BCRYPT_SALT_ROUNDS=10
SESSION_SECRET=your-session-secret-change-in-production

# Optional Features
ENABLE_SWAGGER=true
ENABLE_COMPRESSION=true
ENABLE_HELMET=true
ENABLE_CORS=true

AUTO_MIGRATION=true

# Monitoring
ENABLE_METRICS=false
METRICS_PORT=9100

# Cache
CACHE_TTL=3600 # Time-to-live in seconds
CACHE_MAX=1000 # Maximum number of items in cache
